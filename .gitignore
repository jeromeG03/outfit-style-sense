# =========================
# 1. DEPENDENCIES & BUILD
# =========================
# Ignore the massive Node packages folder (CRITICAL)
node_modules/

# Ignore the Vite production build folder
dist/
dist-ssr/

# =========================
# 2. ENVIRONMENT VARIABLES
# =========================
# Ignore your local secrets and API keys (CRITICAL)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# =========================
# 3. BACKEND (Spring Boot)
# =========================
# Ignore compiled Java code and build artifacts
backend/target/
backend/*.class
backend/*.jar
backend/*.war
backend/log/

# =========================
# 4. MISC & IDE FILES
# =========================
# Ignore personal IDE configurations
.vscode/
.idea/
*.suo
*.sln

# Ignore OS generated files
.DS_Store
Thumbs.db

# Ignore personal prompt history (from your screenshot)
migrated_prompt_history/

# Ignore error logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*